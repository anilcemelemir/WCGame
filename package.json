{
  "name": "wc-lightweight-manager",
  "version": "0.1.0",
  "description": "Online World Cup manager simulation game with React, Vite, Node.js, and WebSocket lobby support.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node server/lobbyServer.mjs",
    "start": "npm run start:server",
    "start:server": "node server/lobbyServer.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc -b --pretty false",
    "test:online": "node scripts/online-smoke.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "ws": "^8.18.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
